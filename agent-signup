<!DOCTYPE html>
<html>

<head>

<title>Agent Sign Up</title>

<meta name="viewport" content="width=device-width, initial-scale=1">

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

<style>

body{
margin:0;
font-family:Arial;
background:#0a1a35;
color:white;
}

/* NAVBAR */

nav{
display:flex;
justify-content:space-between;
padding:20px 60px;
background:#07142b;
}

nav a{
color:white;
margin-left:25px;
text-decoration:none;
font-weight:bold;
}

nav a:hover{
color:#ff7b00;
}

/* FORM */

.container{
max-width:700px;
margin:auto;
padding:60px 20px;
}

form{
background:#112a54;
padding:40px;
border-radius:10px;
}

input,select{
width:100%;
padding:12px;
margin-bottom:15px;
border:none;
border-radius:5px;
}

button{
width:100%;
background:#ff7b00;
border:none;
padding:14px;
color:white;
font-weight:bold;
cursor:pointer;
}

</style>

</head>

<body>

<nav>

<div><b>My Property Agent</b></div>

<div>
<a href="index.html">Home</a>
<a href="find-agents.html">Find Agents</a>
<a href="agent-signup.html">Agent Sign Up</a>
<a href="pricing.html">Pricing</a>
</div>

</nav>


<div class="container">

<h1 style="text-align:center;margin-bottom:30px;">Agent Sign Up</h1>

<form id="agentForm">

<input placeholder="Owner Name" id="owner_name" required>

<input placeholder="Business Name" id="business_name" required>

<input placeholder="Email" id="email">

<input placeholder="Phone" id="phone">

<select id="country"></select>
<select id="state"></select>
<select id="city"></select>

<input placeholder="Zip Code" id="zipcode">

<input placeholder="Website URL" id="website_url">

<label>Profile Image</label>

<input type="file" id="profile_image">

<button type="submit">Submit & Pay</button>

</form>

</div>


<script>

/* SUPABASE */

const supabaseUrl="https://sfysccrjpadcumqakvbz.supabase.co"
const supabaseKey="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InNmeXNjY3JqcGFkY3VtcWFrdmJ6Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzI2OTEyMjAsImV4cCI6MjA4ODI2NzIyMH0.zg-8sziq-2fsbL3LFmGRhSv0m32thTcVS3ZhRb7gn8Y"

const supabase=window.supabase.createClient(supabaseUrl,supabaseKey)


/* LOCATION DROPDOWN */

const country=document.getElementById("country")
const state=document.getElementById("state")
const city=document.getElementById("city")

async function loadCountries(){

const res=await fetch("https://countriesnow.space/api/v0.1/countries")

const data=await res.json()

country.innerHTML="<option>Select Country</option>"

data.data.forEach(c=>{

let option=document.createElement("option")

option.value=c.country
option.textContent=c.country

country.appendChild(option)

})

}

country.addEventListener("change",async()=>{

const res=await fetch("https://countriesnow.space/api/v0.1/countries/states",{

method:"POST",
headers:{"Content-Type":"application/json"},
body:JSON.stringify({country:country.value})

})

const data=await res.json()

state.innerHTML=""

data.data.states.forEach(s=>{

let option=document.createElement("option")

option.value=s.name
option.textContent=s.name

state.appendChild(option)

})

})

state.addEventListener("change",async()=>{

const res=await fetch("https://countriesnow.space/api/v0.1/countries/state/cities",{

method:"POST",
headers:{"Content-Type":"application/json"},
body:JSON.stringify({country:country.value,state:state.value})

})

const data=await res.json()

city.innerHTML=""

data.data.forEach(c=>{

let option=document.createElement("option")

option.value=c
option.textContent=c

city.appendChild(option)

})

})

loadCountries()


/* FORM SUBMIT */

document.getElementById("agentForm").addEventListener("submit",async(e)=>{

e.preventDefault()

const owner_name=document.getElementById("owner_name").value
const business_name=document.getElementById("business_name").value
const email=document.getElementById("email").value
const phone=document.getElementById("phone").value
const countryVal=country.value
const stateVal=state.value
const cityVal=city.value
const zipcode=document.getElementById("zipcode").value
const website_url=document.getElementById("website_url").value

const file=document.getElementById("profile_image").files[0]

let image_url=""

if(file){

const fileName=Date.now()+file.name

await supabase.storage
.from("agent-images")
.upload(fileName,file)

const {data}=supabase.storage
.from("agent-images")
.getPublicUrl(fileName)

image_url=data.publicUrl

}


/* RAZORPAY */

var options={

key:"rzp_live_SNWJWeffEC1xQl",

amount:149900,

currency:"INR",

name:"My Property Agent",

description:"Agent Listing Subscription",

handler: async function () {

/* SAVE AGENT */

const {error}=await supabase

.from("agents")

.insert([{

"Owner Name":owner_name,
business_name,
email,
phone,
country:countryVal,
state:stateVal,
city:cityVal,
zipcode,
website_url,
profile_image:image_url,
subscription_status:"active"

}])

if(error){

alert(error.message)

}else{

alert("Profile Created Successfully!")

window.location.href="index.html"

}

},

theme:{
color:"#ff7b00"
}

}

var rzp=new Razorpay(options)

rzp.open()

})

</script>

</body>

</html>
