<!DOCTYPE html>
<html>

<head>

<title>Find Agents</title>

<meta name="viewport" content="width=device-width, initial-scale=1">

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

<style>

body{
margin:0;
font-family:Arial;
background:#0a1a35;
color:white;
}

/* NAVBAR */

nav{
display:flex;
justify-content:space-between;
padding:20px 60px;
background:#07142b;
}

nav a{
color:white;
margin-left:25px;
text-decoration:none;
font-weight:bold;
}

nav a:hover{
color:#ff7b00;
}

/* PAGE */

.container{
max-width:1200px;
margin:auto;
padding:60px 20px;
}

/* SEARCH */

.search{
display:flex;
gap:10px;
flex-wrap:wrap;
margin-bottom:40px;
justify-content:center;
}

select{
padding:12px;
border:none;
border-radius:5px;
min-width:160px;
}

button{
background:#ff7b00;
border:none;
padding:12px 20px;
color:white;
cursor:pointer;
border-radius:5px;
font-weight:bold;
}

/* AGENT GRID */

.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
gap:25px;
}

/* AGENT CARD */

.card{
background:#112a54;
border-radius:10px;
overflow:hidden;
transition:transform 0.3s;
}

.card:hover{
transform:translateY(-8px);
}

.card img{
width:100%;
height:200px;
object-fit:cover;
}

.card-body{
padding:20px;
text-align:center;
}

.card-body h3{
margin:10px 0;
}

.visit{
margin-top:10px;
display:inline-block;
background:#ff7b00;
padding:10px 15px;
color:white;
text-decoration:none;
border-radius:5px;
}

</style>

</head>

<body>

<!-- NAVBAR -->

<nav>

<div><b>My Property Agent</b></div>

<div>
<a href="index.html">Home</a>
<a href="find-agents.html">Find Agents</a>
<a href="agent-signup.html">Agent Sign Up</a>
<a href="pricing.html">Pricing</a>
</div>

</nav>


<div class="container">

<h1 style="text-align:center;margin-bottom:40px;">Find Real Estate Agents</h1>

<!-- SEARCH -->

<div class="search">

<select id="country"></select>
<select id="state"></select>
<select id="city"></select>

<button onclick="searchAgents()">Search</button>

</div>


<!-- RESULTS -->

<div id="results" class="grid"></div>

</div>


<script>

/* SUPABASE */

const supabaseUrl="https://sfysccrjpadcumqakvbz.supabase.co"
const supabaseKey="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InNmeXNjY3JqcGFkY3VtcWFrdmJ6Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzI2OTEyMjAsImV4cCI6MjA4ODI2NzIyMH0.zg-8sziq-2fsbL3LFmGRhSv0m32thTcVS3ZhRb7gn8Y"

const supabase=window.supabase.createClient(supabaseUrl,supabaseKey)


/* DROPDOWNS */

const country=document.getElementById("country")
const state=document.getElementById("state")
const city=document.getElementById("city")

async function loadCountries(){

const res=await fetch("https://countriesnow.space/api/v0.1/countries")

const data=await res.json()

country.innerHTML="<option>Select Country</option>"

data.data.forEach(c=>{

let option=document.createElement("option")

option.value=c.country
option.textContent=c.country

country.appendChild(option)

})

}

country.addEventListener("change",async()=>{

const res=await fetch("https://countriesnow.space/api/v0.1/countries/states",{

method:"POST",
headers:{"Content-Type":"application/json"},
body:JSON.stringify({country:country.value})

})

const data=await res.json()

state.innerHTML=""

data.data.states.forEach(s=>{

let option=document.createElement("option")

option.value=s.name
option.textContent=s.name

state.appendChild(option)

})

})

state.addEventListener("change",async()=>{

const res=await fetch("https://countriesnow.space/api/v0.1/countries/state/cities",{

method:"POST",
headers:{"Content-Type":"application/json"},
body:JSON.stringify({country:country.value,state:state.value})

})

const data=await res.json()

city.innerHTML=""

data.data.forEach(c=>{

let option=document.createElement("option")

option.value=c
option.textContent=c

city.appendChild(option)

})

})

loadCountries()


/* SEARCH AGENTS */

async function searchAgents(){

const c=country.value
const s=state.value
const ci=city.value

const {data,error}=await supabase

.from("agents")

.select("*")

.eq("country",c)

.eq("state",s)

.eq("city",ci)

displayAgents(data)

}


function displayAgents(agents){

const container=document.getElementById("results")

container.innerHTML=""

agents.forEach(agent=>{

const card=document.createElement("div")

card.className="card"

card.innerHTML=`

<img src="${agent.profile_image || 'https://via.placeholder.com/400'}">

<div class="card-body">

<h3>${agent["Owner Name"]}</h3>

<p>${agent.business_name}</p>

<p>${agent.city}, ${agent.state}</p>

<a class="visit" href="${agent.website_url}" target="_blank">Visit Website</a>

</div>

`

container.appendChild(card)

})

}


/* AUTO SEARCH FROM HOME PAGE */

const params=new URLSearchParams(window.location.search)

const c=params.get("country")
const s=params.get("state")
const ci=params.get("city")

if(c){

country.value=c

setTimeout(()=>{

state.value=s
city.value=ci

searchAgents()

},1500)

}

</script>

</body>

</html>
